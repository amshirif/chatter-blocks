# Foundry deployment inputs
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# CLI defaults
CHATTER_RPC_URL=http://127.0.0.1:8545
CHATTER_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS
CHATTER_PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY

# Optional override for local chat key storage
# CHATTER_HOME=/tmp/chatter-blocks
