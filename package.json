{
  "name": "chatter-blocks",
  "version": "0.1.0",
  "private": true,
  "description": "Foundry-based on-chain direct messaging with a Node CLI and end-to-end encryption.",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "chat": "node cli/cli.js",
    "demo:chain": "bash scripts/demo-local.sh chain",
    "demo:deploy": "bash scripts/demo-local.sh deploy",
    "demo:alice": "bash scripts/demo-local.sh alice",
    "demo:bob": "bash scripts/demo-local.sh bob",
    "demo:clean": "bash scripts/demo-local.sh clean",
    "demo:env": "bash scripts/demo-local.sh env",
    "test:node": "node --test cli/test/*.test.js",
    "test:e2e": "node --test cli/test/e2e/*.test.js",
    "test:sol": "forge test",
    "test": "pnpm test:sol && pnpm test:node && pnpm test:e2e"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "tweetnacl": "^1.0.3",
    "viem": "^2.38.6"
  }
}
